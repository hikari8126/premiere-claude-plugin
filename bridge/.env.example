# ─────────────────────────────────────────────────────────────────────────
# Bridge config — copy this file to .env (without .example) and fill in
# ─────────────────────────────────────────────────────────────────────────

# CLAUDE API MODE (recommended for image parsing)
# Lấy API key tại: https://console.anthropic.com
# Khi có key → bridge dùng Anthropic SDK trực tiếp (nhanh, không rate-limited
# như subscription, tốn $0.003-$0.015 per request tùy model).
# Bỏ comment dòng dưới và paste key vào:
# ANTHROPIC_API_KEY=sk-ant-api03-...

# CLAUDE MODEL (chỉ áp dụng khi có ANTHROPIC_API_KEY)
# Options: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5
# Mặc định: claude-sonnet-4-6 (nhanh + đủ tốt cho image parsing)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# WHISPER CONFIG
# Path đến whisper CLI (default: từ /Library/Frameworks/.../bin/whisper)
# WHISPER_BIN=/Library/Frameworks/Python.framework/Versions/3.14/bin/whisper

# Whisper model: tiny | base | small | medium | large
# Lớn hơn = chậm hơn + chính xác hơn. base ~140MB, small ~466MB
# WHISPER_MODEL=base

# Default ngôn ngữ voiceover
# WHISPER_LANG=en
