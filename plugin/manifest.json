{
  "id": "com.claudeai.premiere-assistant",
  "name": "Claude AI Assistant",
  "version": "4.9.2",
  "manifestVersion": 5,
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "main",
      "label": { "default": "Claude AI" },
      "minimumSize": { "width": 300, "height": 400 },
      "maximumSize": { "width": 900, "height": 2000 },
      "preferredDockedSize": { "width": 360, "height": 640 },
      "preferredFloatingSize": { "width": 400, "height": 640 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "request",
    "network": {
      "domains": [
        "http://localhost:3030",
        "http://127.0.0.1:3030"
      ]
    }
  }
}
